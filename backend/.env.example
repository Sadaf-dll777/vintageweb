# Copy to .env and fill in real values

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vintagestore

# Secret used to sign admin JWTs (any long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Seeded on first migrate run
ADMIN_EMAIL=admin@vintagestore.local
ADMIN_PASSWORD=changeme123

# API server
PORT=4000

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Public URL where uploaded files are served from (no trailing slash)
PUBLIC_BASE_URL=http://localhost:4000