NODE_ENV=development
PORT=4000
APP_URL=http://localhost:8080

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vintagestore

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=replace-with-long-random-string
BETTER_AUTH_URL=http://localhost:4000

# Cloudflare R2 (S3 compatible) — leave empty to use local stub
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vintagestore
R2_PUBLIC_URL=

# Resend — leave empty to log emails instead of sending
RESEND_API_KEY=
EMAIL_FROM=VintageStore <noreply@example.com>
