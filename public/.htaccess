# Hostinger / Apache SPA fallback
# Serves index.html for any route that isn't a real file/directory,
# so client-side routing (/shop, /product/xyz, /admin, etc.) works on refresh.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is not a real file or directory, serve index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Cache immutable hashed assets aggressively
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|woff|ttf|otf|jpg|jpeg|png|webp|avif|svg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Enable gzip / brotli compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Redirect HTTP to HTTPS
<IfModule mod_rewrite.c>
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>